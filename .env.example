# 复制为 .env 后填入真实值
# cp .env.example .env

# 数据库（PostgreSQL，推荐 Neon: neon.tech 免费注册）
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# 会话签名密钥（生产环境务必改为强随机 32+ 字符）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# 站点根 URL（GitHub OAuth 回调地址、MCP 页面用到）
# 本地：http://localhost:3000  ｜  生产：你的 Vercel 域名，如 https://nei-xxx.vercel.app
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# 文件存储：S3 兼容对象存储（Cloudflare R2 / 阿里云 OSS / AWS S3）
# 下列 4 个核心变量齐全（ENDPOINT + ACCESS_KEY_ID + SECRET_ACCESS_KEY + BUCKET_NAME）时启用对象存储；
# 否则 fallback 到下方 UPLOAD_DIR（仅本地开发用）。Vercel 等无状态环境必须配置。
#
# —— Cloudflare R2 填写方式 ——
#   S3_ENDPOINT          = https://<account_id>.r2.cloudflarestorage.com
#                          （account_id 见 R2 概览页 / bucket 的 S3 API 设置）
#   S3_REGION            = auto
#   S3_ACCESS_KEY_ID     = R2 API Token 的 Access Key ID（R2 → Manage R2 API Tokens → 创建 token，勾选 Object Read & Write）
#   S3_SECRET_ACCESS_KEY = 该 token 的 Secret Access Key（创建时只显示一次）
#   S3_BUCKET_NAME       = 你的 bucket 名
#   S3_PUBLIC_URL        = 绑定到 bucket 的公开域名（可选；当前下载走应用自身接口，不强制）
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""
S3_PUBLIC_URL=""

# 本地存储 fallback：未配置上述 S3 时，文件落到此目录（默认 ./uploads）。
# Vercel 等无状态环境必须配置 S3/R2，否则上传的文件会在 serverless 重启后丢失。
UPLOAD_DIR="./uploads"

# 邮件（Resend: resend.com 免费注册，需验证发件域名）
RESEND_API_KEY=""
EMAIL_FROM="N.E.I. <noreply@yourdomain.com>"

# GitHub OAuth（github.com/settings/developers 创建 OAuth App）
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# 管理员引导（首批管理员邮箱，逗号分隔；用户用此邮箱注册 / GitHub 登录时自动成为管理员）
ADMIN_BOOTSTRAP_EMAILS=""

# Memory Node 授权：Ed25519 许可证签发私钥（PEM）。
# 生成：openssl genpkey -algorithm ED25519
# 仅服务端使用，公钥由 Memory Node 客户端编译内置（另一仓库）。未配置则激活签发失败。
MEMORY_LICENSE_PRIVATE_KEY=""

# Vercel Cron 鉴权密钥：保护 /api/cron/cleanup-rate-limits。
# 在 Vercel 项目 Settings → Cron Jobs 配置同名 CRON_SECRET，Vercel 会以 Bearer 调用。
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""

# GLM / 智谱 AI（站内 AI 能力：GitHub 导入转写 + 智能发布辅助「标签/摘要/占位符建议」）
# 用松禾项目自有的 key（open.bigmodel.cn 控制台获取，格式 id.secret）。
# 不配置则「AI 导入」「AI 帮你补全」不可用，其余功能不受影响。
GLM_API_KEY=""
# OpenAI 兼容接口地址。Coding Plan 套餐用 /coding/paas/v4（松禾账户默认）；
# 标准按量计费账户用 /paas/v4。
GLM_BASE_URL="https://open.bigmodel.cn/api/coding/paas/v4"
# 模型名（默认 glm-4.6；可按账号可用的模型改，如 glm-4.5）
GLM_MODEL="glm-4.6"

# 注：网站内不提供「直接执行 Skill」能力；N.E.I. 只分发 Skill / Workflow。
# 用户应通过 MCP 在自己的 Agent 客户端中调用，模型额度、项目材料和本地文件边界由用户客户端控制。
