# 复制为 .env 后填入真实值
# cp .env.example .env

# 数据库（PostgreSQL，推荐 Neon: neon.tech 免费注册）
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# 会话签名密钥（生产环境务必改为强随机 32+ 字符）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# 文件存储：S3 兼容对象存储（阿里云 OSS / Cloudflare R2 / AWS S3）
# 不配则 fallback 到本地 uploads/（Vercel 等无状态环境必须配）
S3_ENDPOINT=""          # OSS: https://oss-cn-hangzhou.aliyuncs.com | R2: https://<account_id>.r2.cloudflarestorage.com
S3_REGION=""            # OSS: oss-cn-hangzhou | R2: auto
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="nei-skills"
S3_PUBLIC_URL=""        # 公开访问域名（OSS 需绑定自定义域名）

# 邮件（Resend: resend.com 免费注册，需验证发件域名）
RESEND_API_KEY=""
EMAIL_FROM="N.E.I. <noreply@yourdomain.com>"

# GitHub OAuth（github.com/settings/developers 创建 OAuth App）
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Anthropic API（AI 转写 GitHub skill 用，console.anthropic.com）
# 不配置则「从 GitHub 导入」功能不可用，其余功能不受影响
ANTHROPIC_API_KEY=""
