// PEVC 知识平台 V1.0 数据模型

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- 用户 ----------
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  nickname     String   @unique
  role         String   // VC / PE / FA
  passwordHash String?
  avatarUrl    String?
  institution  String?  // 机构（选填）
  bio          String?  // 个人简介（选填）
  apiKeyEnc    String?  // Legacy: 站内执行下线前的个人 AI API key 密文字段，保留仅为兼容旧数据
  mcpTokenHash    String?   // Legacy single MCP token hash; new clients use McpAccessToken
  tokenCreatedAt  DateTime? // Legacy token creation time
  tokenLastUsedAt DateTime? // Legacy token last successful authentication
  isAdmin      Boolean  @default(false)  // 管理员
  githubId        String?   @unique
  githubAvatarUrl String?
  githubUsername  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts     Post[]
  comments  Comment[]
  stars     PostFavorite[]
  commentLikes CommentLike[]
  mcpCallLogs McpCallLog[]
  mcpAccessTokens McpAccessToken[]
  reports   Report[]   // SEC-011: 用户提交的举报（作为举报人）
  activityEvents ActivityEvent[]
  consents  UserConsent[] // 协议确认记录

  // 关注关系
  following UserFollow[] @relation("Follower")  // 我关注的人
  followers UserFollow[] @relation("Followee")  // 关注我的人
}

// ---------- MCP 访问凭证 ----------
// 每个 Agent 客户端使用独立、可撤销的 Token。数据库只保存 hash 和末尾提示，不保存明文。
model McpAccessToken {
  id         Int       @id @default(autoincrement())
  userId     Int
  name       String
  clientType String?
  tokenHash  String    @unique
  tokenHint  String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  callLogs McpCallLog[]

  @@index([userId, revokedAt])
  @@index([userId, createdAt])
}

// ---------- 关注 ----------
model UserFollow {
  id         Int      @id @default(autoincrement())
  followerId Int      // 谁
  followeeId Int      // 关注谁
  createdAt  DateTime @default(now())

  follower User @relation("Follower", fields: [followerId], references: [id])
  followee User @relation("Followee", fields: [followeeId], references: [id])

  @@unique([followerId, followeeId])
  @@index([followerId])
  @@index([followeeId])
}

// ---------- 内容 ----------
model Post {
  id           Int      @id @default(autoincrement())
  userId       Int
  title        String
  body         String
  tagScene     String   // 工作场景，必填
  tagIndustry  String?  // 行业赛道
  tagContent   String   // 工作内容，JSON string of array
  tagSkill     String?  // Skill 类型
  status       String   @default("published") // draft / pending / published / rejected
  viewCount    Int      @default(0)
  commentCount Int      @default(0)
  deletedAt    DateTime? // 软删除标记；null = 未删除，非 null = 已删除（不公开可见）
  featured     Boolean  @default(false) // 管理员精选标记；US-012，首页 FeaturedWorkflows 读此字段
  featuredOrder Int    @default(0)      // 精选排序（管理员拖拽控制首页顺序；0 = 默认按时间）
  // --- Sprint 1x MCP 安全字段（SEC-001）---
  mcpApproved   Boolean  @default(false) // 是否允许进 MCP；只有 true 的 skill 才通过 app/api/mcp/route.ts 返回
  reviewFlag    String?  // 审核标记/原因（GLM 安全扫描或人工标记，管理员可见）
  securityLevel String   @default("safe") // safe | suspicious | reject（GLM 安全扫描结论）
  version       Int      @default(1) // skill 版本；编辑触发 +1 且 mcpApproved=false（防 Rug Pull，见 SEC-010）
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  author       User           @relation(fields: [userId], references: [id])
  comments     Comment[]
  attachments  Attachment[]
  stars        PostFavorite[]
  skillAsset   SkillAsset?
  reports      Report[]   // SEC-011: 针对此帖的举报

  @@index([createdAt])
  @@index([tagScene])
  @@index([userId])
  @@index([deletedAt])
}

// ---------- 举报（SEC-011）----------
model Report {
  id         Int      @id @default(autoincrement())
  reporterId Int      // 谁举报
  postId     Int      // 举报哪篇 post
  reason     String   // 举报理由（用户填写）
  status     String   @default("open") // open / closed / dismissed
  createdAt  DateTime @default(now())

  reporter User @relation(fields: [reporterId], references: [id])
  post     Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([status])
}

// ---------- Skill 资产 ----------
model SkillAsset {
  id             Int      @id @default(autoincrement())
  postId         Int      @unique
  assetType      String
  sourceUrl      String?
  originalAuthor String?  // 原作者（搬运帖填，如 Anthropic；普通帖空=作者即发布者）
  installHint    String?
  usageNotes     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([assetType])
}

// ---------- 附件 ----------
model Attachment {
  id            Int      @id @default(autoincrement())
  postId        Int?     // 上传时尚未关联帖子 → null，发帖成功后回填
  uploaderId    Int
  fileName      String
  storageKey    String   // 本地路径 / OSS key
  fileSize      Int
  mimeType      String
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())

  post Post? @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// ---------- 文件对象 fallback ----------
// Public curated .md 已静态化；用户上传附件优先走 S3/R2。
// 如果生产环境暂未配置对象存储，则临时落到 Postgres，避免 Vercel 本地文件丢失。
model StoredFile {
  key       String   @id
  data      Bytes
  mimeType  String
  createdAt DateTime @default(now())
}

// ---------- 评论 ----------
model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  parentId  Int?
  userId    Int
  body      String
  likeCount Int      @default(0)
  createdAt DateTime @default(now())

  post     Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent   Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[]     @relation("CommentReplies")
  author   User          @relation(fields: [userId], references: [id])
  likes    CommentLike[]

  @@index([postId])
  @@index([parentId])
}

model CommentLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

// ---------- Star（收藏+点赞合并）----------
model PostFavorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  sortOrder Int      @default(0)
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
}

// ---------- MCP 调用日志 ----------
model McpCallLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  tokenId    Int?
  postId     Int?
  tool       String
  createdAt  DateTime @default(now())
  clientName String? // SEC-009: 调用方 User-Agent，便于溯源哪个客户端
  latencyMs  Int? // SEC-009: tool 执行耗时（毫秒）
  requestId  String? // SEC-009: 同请求多 tool 共享的随机 id（crypto.randomUUID）

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  token McpAccessToken? @relation(fields: [tokenId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tokenId, createdAt])
  @@index([requestId])
}

// ---------- API 观测样本（管理员 dashboard「服务器压力」用）----------
// 由 lib/metrics.ts withMetrics 采样写入：路由 / 状态码 / 耗时 / 是否出错。
model MetricSample {
  id         Int      @id @default(autoincrement())
  route      String   // 归一化路由，如 "GET /api/mcp"
  status     Int      // HTTP 状态码
  durationMs Int      // 本次请求耗时（毫秒）
  error      Boolean  @default(false) // status >= 500 视为错误
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([route, createdAt])
}

// ---------- 产品行为事件 ----------
model ActivityEvent {
  id          Int      @id @default(autoincrement())
  userId      Int?
  anonymousId String?
  type        String
  entityType  String?
  entityId    Int?
  source      String?
  metadata    Json?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([anonymousId, createdAt])
  @@index([type, createdAt])
  @@index([entityType, entityId])
}

// ---------- 邮箱验证码 ----------
model VerificationCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

// ---------- 用户协议确认记录 ----------
// 记录用户在注册 / 生成 MCP Token / 投稿等关键动作时对协议的确认。
model UserConsent {
  id          Int      @id @default(autoincrement())
  userId      Int
  consentType String   // terms | privacy | mcp_security | contribution
  version     String   // 协议版本，如 "2026-06"
  acceptedAt  DateTime @default(now())
  ipAddress   String?  // 可选，如能获取则记录
  userAgent   String?  // 可选

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, consentType])
}
